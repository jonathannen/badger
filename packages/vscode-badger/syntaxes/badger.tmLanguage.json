{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Badger",
  "scopeName": "source.badger",
  "fileTypes": ["badger"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#doc-comments" },
    { "include": "#strings" },
    { "include": "#raw-strings" },
    { "include": "#chars" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#storage" },
    { "include": "#constants" },
    { "include": "#at-forms" },
    { "include": "#effect-forms" },
    { "include": "#types" },
    { "include": "#function-definition" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "doc-comments": {
      "match": "///.*$",
      "name": "comment.block.documentation.badger"
    },
    "comments": {
      "match": "//(?!/).*$",
      "name": "comment.line.double-slash.badger"
    },
    "strings": {
      "name": "string.quoted.double.badger",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "include": "#string-escapes" }
      ]
    },
    "raw-strings": {
      "name": "string.quoted.double.raw.badger",
      "begin": "r(#*)\"",
      "end": "\"\\1"
    },
    "string-escapes": {
      "patterns": [
        {
          "match": "\\\\([nrt0\\\\\"'])",
          "name": "constant.character.escape.badger"
        },
        {
          "match": "\\\\x[0-9A-Fa-f]{2}",
          "name": "constant.character.escape.hex.badger"
        },
        {
          "match": "\\\\u\\{[0-9A-Fa-f]{1,6}\\}",
          "name": "constant.character.escape.unicode.badger"
        }
      ]
    },
    "chars": {
      "name": "string.quoted.single.badger",
      "match": "'(\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]{1,6}\\}|.)|[^\\\\'])'"
    },
    "numbers": {
      "patterns": [
        {
          "match": "\\b0x[0-9A-Fa-f_]+(?:(i|u)(?:8|16|32|64|128|size))?\\b",
          "name": "constant.numeric.hex.badger"
        },
        {
          "match": "\\b0o[0-7_]+(?:(i|u)(?:8|16|32|64|128|size))?\\b",
          "name": "constant.numeric.octal.badger"
        },
        {
          "match": "\\b0b[01_]+(?:(i|u)(?:8|16|32|64|128|size))?\\b",
          "name": "constant.numeric.binary.badger"
        },
        {
          "match": "\\b[0-9][0-9_]*\\.[0-9_]+(?:[eE][+-]?[0-9_]+)?(f32|f64)?\\b",
          "name": "constant.numeric.float.badger"
        },
        {
          "match": "\\b[0-9][0-9_]*(?:(i|u)(?:8|16|32|64|128|size)|f32|f64)?\\b",
          "name": "constant.numeric.integer.badger"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(match|if|else)\\b",
          "name": "keyword.control.badger"
        },
        {
          "match": "\\b(as|extends)\\b",
          "name": "keyword.other.badger"
        }
      ]
    },
    "storage": {
      "patterns": [
        {
          "match": "\\b(fn)\\b",
          "name": "storage.type.function.badger"
        },
        {
          "match": "\\b(enum|struct|interface|implement|type|extern)\\b",
          "name": "storage.type.badger"
        },
        {
          "match": "\\b(pub)\\b",
          "name": "storage.modifier.badger"
        },
        {
          "match": "\\b(self|Self)\\b",
          "name": "variable.language.self.badger"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b(true|false)\\b",
          "name": "constant.language.boolean.badger"
        }
      ]
    },
    "at-forms": {
      "match": "@[A-Za-z_][A-Za-z0-9_]*",
      "name": "keyword.other.at-form.badger"
    },
    "effect-forms": {
      "match": "![A-Za-z_][A-Za-z0-9_]*",
      "name": "keyword.other.effect.badger"
    },
    "types": {
      "patterns": [
        {
          "match": "\\b(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|bool|char)\\b",
          "name": "support.type.primitive.badger"
        },
        {
          "match": "\\b(String|Option|Result|Void|Init|Main)\\b",
          "name": "support.type.builtin.badger"
        },
        {
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b",
          "name": "entity.name.type.badger"
        }
      ]
    },
    "function-definition": {
      "match": "(?:\\b(extern)\\s+)?\\b([a-z_][A-Za-z0-9_]*)\\s*(?:<[^>]*>)?\\s*(?==\\s*fn\\b)",
      "captures": {
        "1": { "name": "storage.type.badger" },
        "2": { "name": "entity.name.function.badger" }
      }
    },
    "function-call": {
      "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.badger" }
      }
    },
    "operators": {
      "patterns": [
        {
          "match": "=>",
          "name": "keyword.operator.arrow.fat.badger"
        },
        {
          "match": "->",
          "name": "keyword.operator.arrow.thin.badger"
        },
        {
          "match": "\\|>",
          "name": "keyword.operator.pipeline.badger"
        },
        {
          "match": "::",
          "name": "keyword.operator.path.badger"
        },
        {
          "match": "(==|!=|<=|>=|<|>)",
          "name": "keyword.operator.comparison.badger"
        },
        {
          "match": "(&&|\\|\\||!)",
          "name": "keyword.operator.logical.badger"
        },
        {
          "match": "(\\+|-|\\*|/|%)",
          "name": "keyword.operator.arithmetic.badger"
        },
        {
          "match": "(\\?|:)",
          "name": "keyword.operator.ternary.badger"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.badger"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "match": ";",
          "name": "punctuation.terminator.statement.badger"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.badger"
        },
        {
          "match": "\\.",
          "name": "punctuation.accessor.badger"
        }
      ]
    }
  }
}
