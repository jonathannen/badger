pub struct Error {
}

pub interface Read {
  read(self: Self) -> Result<[]u8, Error>;
}

pub interface Write {
  write(self: Self, buffer: []u8) -> Result<usize, Error>;
}

pub interface Stdout {
  print(self: Self, s: String) -> Self !effect(io);
  print_line(self: Self, s: String) -> Self !effect(io);
}

pub interface Stderr {
  print(self: Self, s: String) -> Self !effect(io);
  print_line(self: Self, s: String) -> Self !effect(io);
}

pub interface Stdin extends Read {}
